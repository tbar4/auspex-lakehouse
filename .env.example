# =============================================================================
# auspex_lakehouse environment variables
#
#   cp .env.example .env        # then fill in real values
#
# .env is git-ignored. It is loaded automatically by `dagster dev` locally and
# injected into the containers via `env_file:` in docker-compose.yaml.
# =============================================================================

# ---- Dagster instance Postgres (the docker-compose `auspex_postgres` service) ----
DAGSTER_POSTGRES_USER=postgres_user
DAGSTER_POSTGRES_PASSWORD=postgres_password
DAGSTER_POSTGRES_DB=postgres_db

# ---- NASA API (consumed by dlt as dlt.secrets["nasa_api_key"]) ----
NASA_API_KEY=your_nasa_api_key

# ---- dlt filesystem destination (S3-compatible) ----
# dlt env-var convention: section nesting uses "__", names are upper-cased.
DESTINATION__FILESYSTEM__BUCKET_URL=s3://auspex-lakehouse
DESTINATION__FILESYSTEM__CREDENTIALS__ENDPOINT_URL=https://s3.datadazed.com
DESTINATION__FILESYSTEM__CREDENTIALS__REGION_NAME=us-west-1
DESTINATION__FILESYSTEM__CREDENTIALS__AWS_ACCESS_KEY_ID=your_access_key
DESTINATION__FILESYSTEM__CREDENTIALS__AWS_SECRET_ACCESS_KEY=your_secret_key

# ---- MinIO / bronze bucket (read directly by the apod_images asset & delta.py) ----
# Same physical S3-compatible store as the dlt destination above — usually the
# same access key / secret / endpoint values.
MINIO_ENDPOINT=https://s3.datadazed.com
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
BRONZE_BUCKET_URI=s3://auspex-lakehouse
BRONZE_BUCKET_NAME=auspex-lakehouse

# ---- Deployment image source (only used by docker-compose.prod.yaml / NAS) ----
# After your first push to GitHub, CI publishes images to:
#   ghcr.io/<owner>/<repo>-user-code   and   ghcr.io/<owner>/<repo>-dagster
# Set IMAGE_REPO to "ghcr.io/<owner>/<repo>" (all lowercase). Local dev (which
# builds from source) ignores these.
IMAGE_REPO=ghcr.io/your-gh-username/auspex-lakehouse
IMAGE_TAG=latest

# ---- space-track.org (consumed by dlt as dlt.secrets["spacetrack_username"/"_password"]) ----
SPACETRACK_USERNAME=your_spacetrack_username
SPACETRACK_PASSWORD=your_spacetrack_password
