# --- Secrets: never bake these into an image layer ---
.env
.env.*
**/secrets.toml

# --- Python / virtualenv / caches ---
.venv
**/__pycache__/
*.py[cod]
*.egg-info
.pytest_cache
.ruff_cache
.mypy_cache

# --- Dagster local/runtime artifacts ---
.tmp_dagster_home_*
tmp/
*storage/

# --- VCS / tooling / docs (not needed at runtime) ---
.git
.github
.gitignore
.dg
docs/

# --- dbt local artifacts (regenerated by build-time dbt deps/dbt parse) ---
dbt/target/
dbt/dbt_packages/
dbt/logs/

# --- Local dev DBs / data dumps ---
*.sqlite
*.db
