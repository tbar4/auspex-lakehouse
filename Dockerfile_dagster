# ---------------------------------------------------------------------------
# Dagster control-plane image (webserver + daemon)
#
# Built with uv for tooling consistency with Dockerfile_user_code, but kept
# deliberately thin: the webserver/daemon load user code over gRPC from the
# user-code container, so this image does NOT need the pipeline dependencies.
# Pinned to the same Dagster line as the project (1.13.11 / 0.29.11).
# ---------------------------------------------------------------------------
FROM ghcr.io/astral-sh/uv:python3.10-bookworm-slim

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1

RUN --mount=type=cache,target=/root/.cache/uv \
    uv pip install --system \
        dagster==1.13.11 \
        dagster-graphql==1.13.11 \
        dagster-webserver==1.13.11 \
        dagster-postgres==0.29.11

# $DAGSTER_HOME holds the instance config (dagster.yaml) and workspace.yaml.
ENV DAGSTER_HOME=/opt/dagster/dagster_home/
RUN mkdir -p $DAGSTER_HOME
COPY deploy/dagster.yaml workspace.yaml $DAGSTER_HOME

WORKDIR $DAGSTER_HOME
